{
  "name": "internal-id",
  "version": "0.0.1",
  "description": "Internal OIDC identity provider",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{ts,mjs,json,md,yml}\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "start:prod:migrate": "pnpm migration:run && node dist/src/main",
    "start:prod:full": "pnpm migration:run:compiled && pnpm better-auth:schema:compiled && pnpm seed:bootstrap:compiled && node dist/src/main",
    "sample-client:start": "pnpm exec ts-node --transpile-only sample-client/src/server.ts",
    "lint": "eslint \"{src,apps,libs,test,sample-client}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:migrations": "pnpm migration:verify",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "dependency:audit": "pnpm audit --audit-level moderate --ignore GHSA-p2fr-6hmx-4528",
    "test:e2e": "playwright test",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:run": "pnpm typeorm migration:run",
    "migration:revert": "pnpm typeorm migration:revert",
    "migration:show": "pnpm typeorm migration:show",
    "migration:verify": "pnpm exec ts-node --transpile-only src/database/scripts/verify-migrations.ts",
    "cleanup:expired": "pnpm exec ts-node --transpile-only src/database/scripts/cleanup-expired.ts",
    "seed:bootstrap": "pnpm exec ts-node --transpile-only src/database/scripts/bootstrap.ts",
    "better-auth:inspect": "pnpm exec ts-node --transpile-only src/better-auth/scripts/inspect.ts",
    "better-auth:schema": "pnpm exec ts-node --transpile-only src/better-auth/scripts/materialize-schema.ts",
    "typeorm:compiled": "node ./node_modules/typeorm/cli.js -d dist/src/database/data-source.js",
    "migration:run:compiled": "pnpm typeorm:compiled migration:run",
    "better-auth:schema:compiled": "node dist/src/better-auth/scripts/materialize-schema.js",
    "seed:bootstrap:compiled": "node dist/src/database/scripts/bootstrap.js",
    "admin:install": "pnpm -C web/admin install",
    "admin:dev": "pnpm -C web/admin dev",
    "admin:build": "pnpm -C web/admin build",
    "admin:test": "pnpm -C web/admin test",
    "admin:lint": "pnpm -C web/admin lint",
    "admin:typecheck": "pnpm -C web/admin typecheck",
    "admin:e2e": "pnpm -C web/admin e2e",
    "admin:e2e:install": "pnpm -C web/admin e2e:install"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.20",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/typeorm": "^11.0.1",
    "better-auth": "^1.6.20",
    "express": "5.2.1",
    "kysely": "^0.29.2",
    "nunjucks": "^3.2.4",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.17.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.31",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "form-data": "4.0.6",
      "js-yaml": "4.3.0",
      "multer": "2.2.0",
      "brace-expansion": "^5.0.8",
      "fast-uri": "^4.1.1"
    },
    "auditConfig": {
      "ignoreCves": [
        "GHSA-p2fr-6hmx-4528"
      ]
    }
  },
  "packageManager": "pnpm@10.12.4"
}
